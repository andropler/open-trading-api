# 5m Composite Live Trader — 환경변수 템플릿
# 사용: cp backtester/.env.live.example backtester/.env.live  → 값 채워 넣기 → chmod 600
# 로딩: LiveConfig.from_env(Path("backtester/.env.live"))

# ────────────────────────────────────────────────────
# 운영 모드
# ────────────────────────────────────────────────────
# vps  = KIS 모의투자 (페이퍼)
# prod = KIS 실전투자 (라이브)
COMPOSITE_TRADER_MODE=vps

# 운용 자본 (KRW). max_positions=1 전략이므로 종목당 이 금액 전액 배정
COMPOSITE_TRADER_CAPITAL_KRW=5000000

# 킬스위치 한도 (선택, 기본값 daily=3.0 / cumulative=8.0)
# COMPOSITE_TRADER_DAILY_LOSS_PCT=3.0
# COMPOSITE_TRADER_CUMULATIVE_LOSS_PCT=8.0

# ────────────────────────────────────────────────────
# 텔레그램 봇
# ────────────────────────────────────────────────────
# @BotFather 로 봇 생성 → 토큰
TG_BOT_TOKEN=
# 알림 받을 채널/개인 chat_id (https://t.me/userinfobot 으로 확인)
TG_CHAT_ID=

# ────────────────────────────────────────────────────
# KIS Open API — 모의(vps)
# ────────────────────────────────────────────────────
KIS_VPS_APPKEY=
KIS_VPS_APPSECRET=
KIS_VPS_ACCOUNT_NO=

# ────────────────────────────────────────────────────
# KIS Open API — 실전(prod) (mode=prod 일 때만 필요)
# ────────────────────────────────────────────────────
# KIS_PROD_APPKEY=
# KIS_PROD_APPSECRET=
# KIS_PROD_ACCOUNT_NO=
